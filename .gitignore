# ==========================================================================
# My Health Coach — Next.js 15 (App Router) + TypeScript + better-sqlite3
# See https://help.github.com/articles/ignoring-files/
# ==========================================================================

# --- Dependencies ---------------------------------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/install-state.gz

# --- Next.js build output -------------------------------------------------
/.next/
/out/
/build
/dist
next-env.d.ts

# --- TypeScript -----------------------------------------------------------
*.tsbuildinfo

# --- Output/ — all runtime file storage (PRD §9 #spec-meta) ----------------
# DB, documents, exports, uploads, logs. Recreated by `npm run seed`.
/Output/

# --- Generated SQLite database --------------------------------------------
# Per PRD §9: ./data/hteap-demo.db is generated and gitignored; it is
# (re)created deterministically by `npm run seed`. Ignore the DB and any
# WAL/SHM/journal sidecar files better-sqlite3 may produce, but keep the
# data/ directory itself tracked (via data/.gitkeep) so seeding has a target.
/data/*.db
/data/*.db-wal
/data/*.db-shm
/data/*.db-journal
/data/*.sqlite
/data/*.sqlite3

# --- Testing / coverage ---------------------------------------------------
/coverage
/.nyc_output
/playwright-report/
/test-results/

# --- Local env files ------------------------------------------------------
# This is a demo with zero secrets, but never commit machine-local env.
.env
.env.local
.env.*.local

# --- Logs & debug ---------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Editor / OS cruft ----------------------------------------------------
.DS_Store
*.pem
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# --- Deploy ---------------------------------------------------------------
.vercel

# --- Claude Code local settings (machine-specific) ------------------------
.claude/settings.local.json
# NOTE: .claude/skills/ is intentionally tracked (real files, not symlinks)
# so teammates get the skills on a plain clone. Mirrors .agents/skills/.
