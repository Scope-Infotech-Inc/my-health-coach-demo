{
  "title": "HTEAP Diabetes & Obesity Demo Application",
  "version": "1.3",
  "date": "2026-06-11",
  "stack": {
    "framework": "next.js >=15 (app router)",
    "language": "typescript",
    "db": "sqlite (better-sqlite3) at Output/db/hteap-demo.db",
    "styling": "css custom properties + css modules",
    "charts": "custom svg",
    "fonts": [
      "Public Sans",
      "Lexend"
    ],
    "fontDelivery": "next/font/google (self-hosted at build)",
    "voice": "browser-native Web Speech API (optional, graceful fallback)",
    "assistant": "deterministic on-device intent engine (NO LLM), behind interpret() swap seam"
  },
  "fileStorage": {
    "baseDir": "Output",
    "resolution": "path.resolve(process.cwd(), 'Output')",
    "envOverride": "HTEAP_OUTPUT_DIR",
    "resolvedIn": "lib/paths.ts",
    "subdirs": {
      "db": "Output/db",
      "documents": "Output/documents",
      "exports": "Output/exports",
      "uploads": "Output/uploads",
      "logs": "Output/logs"
    },
    "createdOnDemand": true,
    "gitignored": true,
    "noWritesOutsideBaseDir": true
  },
  "demoToday": "2026-06-06",
  "breakpointPx": 880,
  "innerDesktopCollapsePx": [
    1100,
    700
  ],
  "routes": [
    "/",
    "/how-it-works",
    "/rewards",
    "/devices",
    "/connect",
    "/assistant",
    "/nearby",
    "/recipes",
    "/share",
    "/records",
    "/api/*"
  ],
