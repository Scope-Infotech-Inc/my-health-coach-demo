npx lint-staged

# Secret scanning: block commits that introduce secrets (gitleaks).
# Scans only the staged changes. Bypass in a true emergency with
# `git commit --no-verify` — the pull request gate will still block the merge.
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "✖ gitleaks is required by the pre-commit secret scan but was not found."
  echo "  Install it, then commit again:"
  echo "    macOS:  brew install gitleaks"
  echo "    other:  https://github.com/gitleaks/gitleaks#installing"
  exit 1
fi

gitleaks git --staged --redact --no-banner --verbose
